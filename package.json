{
  "name": "trae-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "start": "node server.mjs",
    "vercel:pull:prod": "vercel pull --yes --environment=production",
    "vercel:build:prod": "vercel build --prod",
    "vercel:deploy:prebuilt:prod": "vercel deploy --prebuilt --prod --yes",
    "deploy:prod": "npm run vercel:pull:prod && npm run vercel:build:prod && npm run vercel:deploy:prebuilt:prod",
    "deploy:prod:simple": "vercel --prod --yes"
  },
  "dependencies": {
    "@google-cloud/translate": "^9.3.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@supabase/supabase-js": "^2.96.0",
    "@types/three": "^0.182.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.1",
    "i18next": "^25.8.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "shopify-buy": "^3.0.7",
    "tailwind-merge": "^3.4.1",
    "three": "^0.182.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.24",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
